# ========================================
# AutoClip 环境变量配置示例
# ========================================
# 复制此文件为 .env 并填写真实的配置值
# 注意：.env 文件包含敏感信息，请勿提交到版本控制

# ========================================
# 应用基础配置
# ========================================
ENVIRONMENT=development
DEBUG=true
ENCRYPTION_KEY=
AUTO_CLIPS_MASTER_PASSWORD=your_master_password_here

# ========================================
# 数据库配置
# ========================================
# SQLite 数据库路径
DATABASE_URL=sqlite:///./data/autoclip.db

# ========================================
# Redis 配置
# ========================================
# Redis 连接 URL（用于 Celery 任务队列和缓存）
REDIS_URL=redis://localhost:6379/0

# ========================================
# LLM API 配置
# ========================================
# LLM 提供商: dashscope | openai | gemini | siliconflow | custom
LLM_PROVIDER=dashscope

# DashScope (通义千问) API 配置
API_DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
API_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_MODEL_NAME=qwen-plus
MODEL_NAME=qwen-plus
API_MAX_TOKENS=4096
MAX_TOKENS=4096
API_TIMEOUT=600

# OpenAI 配置（可选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini 配置（可选）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# SiliconFlow 配置（可选）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Claude 配置（可选）
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# 自定义提供商配置（可选）
# 支持任何 OpenAI 兼容的 API
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_BASE_URL=https://your-api-endpoint.com/v1
CUSTOM_MODELS_URL=
CUSTOM_MODEL_NAME=your-model
CUSTOM_API_FORMAT=openai

# ========================================
# LLM 生成参数
# ========================================
TEMPERATURE=0.7
TOP_P=0.9
MAX_RETRIES=3
TIMEOUT_SECONDS=600

# ========================================
# Celery 任务队列配置
# ========================================
# 任务模式：false=异步执行（生产环境），true=同步执行（调试环境）
CELERY_ALWAYS_EAGER=false
# Worker 并发数
CELERY_CONCURRENCY=4

# ========================================
# 视频处理配置
# ========================================
# 文本分块大小（字符数）
PROCESSING_CHUNK_SIZE=3000
CHUNK_SIZE=5000
# 最小评分阈值（100分制）
PROCESSING_MIN_SCORE_THRESHOLD=70
MIN_SCORE_THRESHOLD=70
# 每个合集最大切片数
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
# 最大重试次数
PROCESSING_MAX_RETRIES=3

# ========================================
# 话题提取控制参数
# ========================================
# 话题最小时长（分钟）
MIN_TOPIC_DURATION_MINUTES=2
# 话题最大时长（分钟）
MAX_TOPIC_DURATION_MINUTES=12
# 话题目标时长（分钟）
TARGET_TOPIC_DURATION_MINUTES=5
# 每个文本块最少话题数
MIN_TOPICS_PER_CHUNK=3
# 每个文本块最多话题数
MAX_TOPICS_PER_CHUNK=8

# ========================================
# 视频编码优化配置
# ========================================
# 是否使用流复制（推荐 true，速度最快）
VIDEO_USE_STREAM_COPY=true
# 是否使用硬件加速（需要 GPU）
VIDEO_USE_HARDWARE_ACCEL=true
# 编码预设（p1-p7，p6 为平衡）
VIDEO_ENCODER_PRESET=p6
# 视频质量（18-28，越小质量越好）
VIDEO_CRF=18

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# 日志格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# 日志文件路径
LOG_FILE=logs/backend.log

# ========================================
# B站 Cookie 配置
# ========================================
# 用于 bcut-asr 语音识别服务
# 获取方式：登录 B站后从浏览器开发者工具中复制完整的 Cookie 字符串
BILIBILI_COOKIE=your_bilibili_cookie_here

# ========================================
# 代理配置（可选）
# ========================================
# 如需使用代理，取消注释并配置
# PROXY_URL=http://127.0.0.1:7890
PROXY_URL=

# ========================================
# 前端配置
# ========================================
# 前端开发服务器端口
VITE_PORT=5173
# 后端 API 地址
VITE_API_URL=http://localhost:8000
